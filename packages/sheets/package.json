{
  "name": "@constructive-io/sheets",
  "version": "0.5.0",
  "description": "Portable, extensible spreadsheet-like CRUD grid for PostGraphile (or any) backends",
  "private": false,
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./advanced": {
      "import": {
        "types": "./dist/advanced.d.ts",
        "default": "./dist/advanced.js"
      },
      "require": {
        "types": "./dist/advanced.d.cts",
        "default": "./dist/advanced.cjs"
      }
    },
    "./auth": {
      "import": {
        "types": "./dist/auth.d.ts",
        "default": "./dist/auth.js"
      },
      "require": {
        "types": "./dist/auth.d.cts",
        "default": "./dist/auth.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      },
      "require": {
        "types": "./dist/testing.d.cts",
        "default": "./dist/testing.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup && cp src/styles.css dist/styles.css",
    "build:vendor": "tsup --config tsup.vendor.config.ts",
    "dev": "tsup --watch",
    "lint:types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "sb": "storybook dev -p 6008",
    "build-sb": "storybook build"
  },
  "peerDependencies": {
    "@constructive-io/data": "workspace:*",
    "@constructive-io/ui": "workspace:*",
    "@internationalized/date": "^3",
    "@tanstack/react-form": ">=0.40",
    "@tanstack/react-query": "^5",
    "leaflet": "^1",
    "react": ">=18",
    "react-aria-components": ">=1",
    "react-dom": ">=18",
    "react-leaflet": "^5"
  },
  "peerDependenciesMeta": {
    "@internationalized/date": {
      "optional": true
    },
    "react-aria-components": {
      "optional": true
    },
    "leaflet": {
      "optional": true
    },
    "react-leaflet": {
      "optional": true
    }
  },
  "dependencies": {
    "@remixicon/react": "^4.9.0",
    "@tanstack/react-table": "9.0.0-beta.17",
    "@tanstack/react-virtual": "^3.14.3",
    "clsx": "^2",
    "graphql": "^16",
    "inflekt": "^0.5.1",
    "lucide-react": "^0.525.0",
    "motion": ">=11",
    "tailwind-merge": "^3",
    "zod": "^4",
    "zustand": "^5"
  },
  "devDependencies": {
    "@constructive-io/data": "workspace:*",
    "@constructive-io/ui": "workspace:*",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-form": ">=0.40",
    "@tanstack/react-query": "^5",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^26.1.0",
    "react": "^19",
    "react-dom": "^19",
    "storybook": "^10.1.11",
    "tailwindcss": "^4.1.18",
    "tsup": "^8",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9",
    "vite": "^7.3.0",
    "vitest": "^3"
  }
}
