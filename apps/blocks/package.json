{
  "name": "blocks",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "gen": "node scripts/generate-manifest.mjs && node scripts/generate-flows.mjs",
    "gen:check": "node scripts/check-generated.mjs",
    "gen:flows": "node scripts/generate-flows.mjs",
    "fixtures:refresh": "node scripts/refresh-sdk-fixtures.mjs",
    "fixtures:check": "node scripts/check-sdk-fixtures.mjs",
    "build:registry": "pnpm --filter @constructive-io/registry build",
    "check:flows": "node scripts/check-flows.mjs && node scripts/check-install-namespace.mjs && node scripts/check-sdk-fixtures.mjs",
    "check:install-namespace": "node scripts/check-install-namespace.mjs",
    "check:selections": "node scripts/check-mutation-selections.mjs",
    "predev": "node scripts/generate-manifest.mjs && node scripts/generate-flows.mjs",
    "prebuild": "pnpm gen:check",
    "dev": "next dev --turbopack --port 3005",
    "build": "next build",
    "build:pages": "BLOCKS_PAGES=1 next build",
    "start": "next start --port 3005",
    "lint:types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots=all"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.14",
    "@ai-sdk/openai-compatible": "^3.0.9",
    "@ai-sdk/react": "^4.0.27",
    "@0no-co/graphql.web": "^1.2.0",
    "@base-ui/react": "^1.0.0",
    "@constructive-io/graphql-types": "^3.4.3",
    "@constructive-io/schema-builder": "workspace:*",
    "@constructive-io/ui": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@fluentui/react-context-selector": "^9.2.13",
    "@paper-design/shaders-react": "0.0.77",
    "@pgsql/types": "^17.6.2",
    "@remixicon/react": "^4.8.0",
    "@tanstack/react-form": "^1.27.7",
    "@tanstack/react-query": "^5.90.16",
    "ai": "^7.0.26",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "gsap": "^3.15.0",
    "gql-ast": "^3.3.3",
    "graphql": "16.13.0",
    "lucide-react": "^0.525.0",
    "marked": "^16.4.2",
    "motion": "^12.40.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "node-type-registry": "0.48.0",
    "pg-ast": "^2.11.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@simplewebauthn/browser": "^13.3.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^26.1.0",
    "shadcn": "^3.8.3",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
