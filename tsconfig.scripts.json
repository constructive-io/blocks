{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "types": ["node"],
    "allowImportingTsExtensions": true
  },
  "include": [
    "scripts/**/*.ts",
    "apps/*/scripts/**/*.ts",
    "apps/blocks/e2e/**/*.ts",
    "packages/*/scripts/**/*.ts"
  ]
}
